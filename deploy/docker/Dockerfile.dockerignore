# Scoped ignore for deploy/docker/Dockerfile (BuildKit reads <Dockerfile>.dockerignore).
# Keep the build context lean and force a clean install/build inside the image.
**/node_modules
**/dist
.git
.pnpm-store
**/.turbo
**/*.log
# Local runtime state + secrets — the container gets its config via mounts, never the image.
**/.cotal
**/signer.json
**/.env
