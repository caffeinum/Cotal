{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/node_modules/.bin/tsx",
            "args": ["${CLAUDE_PLUGIN_ROOT}/src/hook.ts"]
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/node_modules/.bin/tsx",
            "args": ["${CLAUDE_PLUGIN_ROOT}/src/hook.ts"]
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/node_modules/.bin/tsx",
            "args": ["${CLAUDE_PLUGIN_ROOT}/src/hook.ts"]
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/node_modules/.bin/tsx",
            "args": ["${CLAUDE_PLUGIN_ROOT}/src/hook.ts"]
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/node_modules/.bin/tsx",
            "args": ["${CLAUDE_PLUGIN_ROOT}/src/hook.ts"]
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/node_modules/.bin/tsx",
            "args": ["${CLAUDE_PLUGIN_ROOT}/src/hook.ts"]
          }
        ]
      }
    ]
  }
}
